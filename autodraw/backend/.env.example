# Optional SAM API keys (recommended for Docker users)
# Recommended UTF-8 runtime settings for Railway / containers
PYTHONIOENCODING=utf-8
LANG=C.UTF-8
LC_ALL=C.UTF-8

QINGYUN_BASE_URL=https://api.qingyuntop.top/v1
QINGYUN_GEMINI_BASE_URL=
DEFAULT_IMAGE_MODEL=
DEFAULT_SVG_MODEL=
QINGYUN_IMAGE_MODEL=
QINGYUN_SVG_MODEL=
BIANXIE_IMAGE_MODEL=
BIANXIE_SVG_MODEL=
OPENROUTER_IMAGE_MODEL=
OPENROUTER_SVG_MODEL=
GEMINI_IMAGE_MODEL=
GEMINI_SVG_MODEL=
ROBOFLOW_API_KEY=
FAL_KEY=
SAM3_API_KEY=
# Optional fal proxy base URL (e.g. https://api.qingyuntop.top)
FAL_BASE_URL=
# Optional direct fal API override (default is official fal.run endpoint)
FAL_API_URL=
SAM3_API_URL=
ROBOFLOW_API_URL=https://serverless.roboflow.com
ROBOFLOW_WORKSPACE_NAME=s-workspace-qcgw5
ROBOFLOW_WORKFLOW_ID=general-segmentation-api
ROBOFLOW_IMAGE_INPUT_NAME=image
ROBOFLOW_API_FALLBACK_URLS=

# Required for RMBG-2.0 (gated HuggingFace model)
# 1) Request access at https://huggingface.co/briaai/RMBG-2.0
# 2) Create a Read token and set it below
HF_TOKEN=

# Background removal provider
# local: use local RMBG model (for local development)
# remote: use fal.ai BiRefNet (recommended on Railway)
# auto: fallback to local
BACKGROUND_REMOVAL_PROVIDER=local
# Reuse FAL_KEY when possible; BACKGROUND_REMOVAL_API_KEY can override it for this feature only
BACKGROUND_REMOVAL_API_KEY=
BACKGROUND_REMOVAL_FAL_MODEL=fal-ai/birefnet
# Optional: png / webp / gif
BACKGROUND_REMOVAL_REMOTE_FORMAT=png
# Optional: General Use (Light) / General Use (Heavy) / Portrait
BACKGROUND_REMOVAL_FAL_MODEL_VARIANT=General Use (Light)
# Optional: 1024x1024 / 2048x2048
BACKGROUND_REMOVAL_FAL_OPERATING_RESOLUTION=1024x1024
# Optional: true / false
BACKGROUND_REMOVAL_FAL_REFINE_FOREGROUND=true

# Optional: OpenRouter multimodal retry tuning (step 4 SVG generation)
# OPENROUTER_MULTIMODAL_RETRIES=3
# OPENROUTER_MULTIMODAL_RETRY_DELAY=1.5
# Optional: prefer Qingyun Gemini native multimodal for step 4 SVG generation
# QINGYUN_SVG_PREFER_NATIVE=false
# Optional: cap max_tokens for step 4 multimodal requests to reduce long non-stream response failures
# SVG_MULTIMODAL_MAX_TOKENS=24000

# Optional build source overrides (for restricted networks)
# BASE_IMAGE=docker.m.daocloud.io/library/python:3.11-slim
# PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
# PIP_EXTRA_INDEX_URL=

# Optional container DNS override (for Roboflow DNS resolution issues)
# DOCKER_DNS_1=223.5.5.5
# DOCKER_DNS_2=119.29.29.29
